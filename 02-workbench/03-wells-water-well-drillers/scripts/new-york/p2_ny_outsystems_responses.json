  {
    "url": "https://appfactory.dec.ny.gov/WaterWell/screenservices/WaterWell/MainFlow/Contractor_Search/ScreenDataSetGetServiceDefinitions",
    "data": {
      "versionInfo": {
        "hasModuleVersionChanged": false,
        "hasApiVersionChanged": false
      },
      "data": {
        "List": {
          "List": [
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Residential Wells",
                "Definitions": "Wells constructed as a source of potable water for individual households"
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Public Wells",
                "Definitions": "Wells constructed for use as regulated public water supplies."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Commercial Wells",
                "Definitions": "Wells constructed for use in commercial business activities."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Geothermal Wells",
                "Definitions": "Wells constructed for use in space heating or cooling, or other applications involving the use or transfer of groundwater heat. For wells greater than 500 feet, refer to\u00a0DEC permitting requirements."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Agricultural Wells",
                "Definitions": "Wells constructed for irrigation of farmland or as a water supply for livestock."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Environmental Monitoring",
                "Definitions": "Wells constructed to monitor the physical or chemical character of groundwater."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Geotechnical Wells",
                "Definitions": "Wells constructed to characterize subsurface geology or for dewatering during construction activity."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Injection Wells",
                "Definitions": "Wells constructed for the use of placing fluid underground. Permits for injection wells are obtained from the\u00a0US EPA Underground Injection Control\u00a0program."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Irrigation Wells",
                "Definitions": "Wells constructed for irrigation of properties such as homes and golf courses."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Drilling: Dewatering Wells",
                "Definitions": "Wells or boreholes constructed or used for the sole purpose of lowering or controlling the level of groundwater."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Well Deepening",
                "Definitions": "Drilling an existing well deeper."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Well Decommissioning",
                "Definitions": "Permanent closure of a well by physically removing the well from service."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Control Overflowing Wells",
                "Definitions": "Control of a water well such that water no longer flows beyond the well casing."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Pump Installation",
                "Definitions": "Installation of new water well pumps."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Pump Service",
                "Definitions": "Service of existing water well pumps."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Disinfection",
                "Definitions": "Introduction and circulation of a carefully determined amount of an approved disinfection solution to a water well for treatment of bacteria. Additional information is available from your local Health Department."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Hydrofracturing",
                "Definitions": "The process where fluid is pumped down a well at high pressures to open fractures in adjacent rock to improve water flow to the well."
              }
            },
            {
              "ServiceDefinitions": {
                "Id": "0",
                "Service": "Cleaning/Redevelopment",
                "Definitions": "Physical or chemical process intended to removed sediment, scale, or other material that may be interfering with the amount of water available for pumping."
              }
            }
          ]
        },
        "Count": -1
      },
      "rolesInfo": ","
    }
